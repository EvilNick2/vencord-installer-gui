[
  {
    "id": "node",
    "name": "Node.js",
    "command": "node",
    "args": ["--version"],
    "recommendedVersion": "22.14.0",
    "installCommands": {
      "windows": {
        "command": "powershell",
        "args": ["-Command", "winget install -e --id OpenJS.NodeJS.LTS --source winget --accept-source-agreements --accept-package-agreements"],
        "displayLabel": "Install with winget"
      },
      "macos": {
        "command": "brew",
        "args": ["install", "node@22"],
        "displayLabel":"Install with Homebrew"
      },
      "linux": {
        "debian": {
          "command": "bash",
          "args": ["-c", "curl -fsSL https://deb.nodesource.com/setup_22.x | sudo -E bash - && sudo apt-get install -y nodejs"],
          "displayLabel":"Install with NodeSource (Debian/Ubuntu)"
        },
        "fedora": {
          "command": "sudo",
          "args": ["dnf", "install", "-y", "nodejs", "npm"],
          "displayLabel":"Install with dnf"
        },
        "arch": {
          "command": "sudo",
          "args": ["pacman", "-Sy", "--noconfirm", "nodejs", "npm"],
          "displayLabel":"Install with pacman"
        },
        "suse": {
          "command": "bash",
          "args": ["-c", "sudo zypper --non-interactive install nodejs22 npm22 || sudo zypper --non-interactive install nodejs npm"],
          "displayLabel":"Install with zypper"
        },
        "alpine": {
          "command": "sudo",
          "args": ["apk", "add", "--no-cache", "nodejs", "npm"],
          "displayLabel":"Install with apk"
        },
        "default": {
          "command": "bash",
          "args": ["-c", "echo \"Unsupported Linux distribution. Please install Node.js 22+ manually.\" && exit 1"],
          "displayLabel":"Manual install required"
        }
      }
    }
  },
  {
    "id": "npm",
    "name": "npm",
    "command": "npm",
    "args": ["--version"],
    "recommendedVersion": "11.6.2",
    "installCommands": {
      "windows": {
        "command": "npm",
        "args": ["install", "-g", "npm@{version}"],
        "displayLabel": "Upgrade npm globally"
      },
      "macos": {
        "command": "npm",
        "args": ["install", "-g", "npm@{version}"],
        "displayLabel": "Upgrade npm globally"
      },
      "linux": {
        "command": "npm",
        "args": ["install", "-g", "npm@{version}"],
        "displayLabel": "Upgrade npm globally"
      }
    }
  },
  {
    "id": "pnpm",
    "name": "pnpm",
    "command": "pnpm",
    "args": ["--version"],
    "recommendedVersion": "10.32.1",
    "installCommands": {
      "windows": {
        "command": "npm",
        "args": ["install", "-g", "pnpm@{version}"],
        "displayLabel": "Install pnpm globally"
      },
      "macos": {
        "command": "npm",
        "args": ["install", "-g", "pnpm@{version}"],
        "displayLabel": "Install pnpm globally"
      },
      "linux": {
        "command": "npm",
        "args": ["install", "-g", "pnpm@{version}"],
        "displayLabel": "Install pnpm globally"
      }
    }
  },
  {
    "id": "git",
    "name": "Git",
    "command": "git",
    "args": ["--version"],
    "recommendedVersion": "2.53.0",
    "installCommands": {
      "windows": {
        "command": "powershell",
        "args": ["-Command", "winget install -e --id Git.Git --source winget --accept-source-agreements --accept-package-agreements"],
        "displayLabel": "Install with winget"
      },
      "macos": {
        "command": "brew",
        "args": ["install", "git"],
        "displayLabel": "Install with Homebrew"
      },
      "linux": {
        "debian": {
          "command": "bash",
          "args": ["-c", "sudo apt-get update && sudo apt-get install -y git"],
          "displayLabel":"Install with apt"
        },
        "fedora": {
          "command": "sudo",
          "args": ["dnf", "install", "-y", "git"],
          "displayLabel":"Install with dnf"
        },
        "arch": {
          "command": "sudo",
          "args": ["pacman", "-Sy", "--noconfirm", "git"],
          "displayLabel":"Install with pacman"
        },
        "suse": {
          "command": "sudo",
          "args": ["zypper", "--non-interactive", "install", "git"],
          "displayLabel":"Install with zypper"
        },
        "alpine": {
          "command": "sudo",
          "args": ["apk", "add", "--no-cache", "git"],
          "displayLabel":"Install with apk"
        },
        "default": {
          "command": "bash",
          "args": ["-c", "echo \"Unsupported Linux distribution. Please install Git manually.\" && exit 1"],
          "displayLabel":"Manual install required"
        }
      }
    }
  }
]